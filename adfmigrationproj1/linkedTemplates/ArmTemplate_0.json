		"LS_onprem_adls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevmigration.dfs.core.windows.net/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
