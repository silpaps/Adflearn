					"url": "[parameters('LS_getmetadata_sales_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('LS_getmetadata_sales_accountKey')]"
					}
				}
			},
			"dependsOn": []
