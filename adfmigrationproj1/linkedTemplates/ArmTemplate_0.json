		},
		"LS_onprem_adls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_onprem_adls'"
		},
		"DS_OUTPUT_Binary1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevmigration.dfs.core.windows.net/"
