			"metadata": "Secure string for 'accountKey' of 'DS_OUTPUT_Binary1'"
		},
		"DS_output_csv_parque_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DS_output_csv_parque'"
		},
		"LS_Binary1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Binary1'"
		},
		"LS_Blobstorage_lookup_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blobstorage_lookup'"
		},
		"LS_MULTIPLECSVS_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_MULTIPLECSVS'"
